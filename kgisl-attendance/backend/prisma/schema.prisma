// ============================================================
// KGiSL-IIM Smart Attendance — Dynamic QR Module
// Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// Reference / supporting entities (minimal — extend as needed)
// ------------------------------------------------------------

model Faculty {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true) @map("is_active")

  sessions    AttendanceSession[]
  allocations TimetableAllocation[]

  @@map("faculty")
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  isActive     Boolean  @default(true) @map("is_active")

  @@map("admin")
}

model Student {
  id           String   @id @default(uuid())
  name         String
  rollNo       String   @unique @map("roll_no")
  regNo        String   @unique @map("reg_no")
  batchId      String   @map("batch_id")
  email        String   @unique
  passwordHash String
  deviceId     String?  @map("device_id") // bound device for anti-sharing checks
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true) @map("is_active")

  batch         Batch              @relation(fields: [batchId], references: [id])
  records       AttendanceRecord[]
  leaveRequests LeaveRequest[]

  @@map("student")
}

model Batch {
  id           String                @id @default(uuid())
  name         String                @unique // e.g. "MCA - II Year A"
  department   String                @default("Computer Applications")
  programme    String                @default("MCA")
  semester     Int                   @default(1)
  academicYear String                @default("2026-2027") @map("academic_year")
  students     Student[]
  sessions     AttendanceSession[]
  allocations  TimetableAllocation[]

  @@map("batch")
}

model Subject {
  id          String                @id @default(uuid())
  name        String
  code        String                @unique
  sessions    AttendanceSession[]
  allocations TimetableAllocation[]

  @@map("subject")
}

model Room {
  id                 String                @id @default(uuid())
  name               String                @unique // e.g. "302 - MCA Lab"
  latitude           Float
  longitude          Float
  geofenceRadiusM    Int                   @default(120) @map("geofence_radius_m")
  wifiBssidWhitelist String[]              @map("wifi_bssid_whitelist")
  sessions           AttendanceSession[]
  allocations        TimetableAllocation[]

  @@map("room")
}

model TimetableAllocation {
  id        String   @id @default(uuid())
  facultyId String   @map("faculty_id")
  subjectId String   @map("subject_id")
  batchId   String   @map("batch_id")
  roomId    String   @map("room_id")
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time")
  endTime   String   @map("end_time")
  createdAt DateTime @default(now()) @map("created_at")

  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])

  @@unique([facultyId, dayOfWeek, startTime])
  @@index([facultyId, dayOfWeek])
  @@map("timetable_allocation")
}

// ------------------------------------------------------------
// Core attendance tables (as specified in requirements)
// ------------------------------------------------------------

enum SessionStatus {
  ACTIVE
  PAUSED
  ENDED
  EXPIRED
}

model AttendanceSession {
  sessionId      String        @id @default(uuid()) @map("session_id")
  facultyId      String        @map("faculty_id")
  subjectId      String        @map("subject_id")
  roomId         String        @map("room_id")
  batchId        String        @map("batch_id")
  status         SessionStatus @default(ACTIVE)
  startedAt      DateTime      @default(now()) @map("started_at")
  endedAt        DateTime?     @map("ended_at")
  scheduledEndAt DateTime?     @map("scheduled_end_at")
  sessionType    String        @default("SCHEDULED") @map("session_type")
  notes          String?

  // Only a HASH of the currently active token is ever persisted.
  currentQrTokenHash String?   @map("current_qr_token_hash")
  currentQrExpiry    DateTime? @map("current_qr_expiry")

  createdAt DateTime @default(now()) @map("created_at")

  faculty Faculty @relation(fields: [facultyId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])
  batch   Batch   @relation(fields: [batchId], references: [id])

  qrHistory AttendanceQrHistory[]
  records   AttendanceRecord[]

  @@index([status])
  @@map("attendance_session")
}

model AttendanceQrHistory {
  id              String    @id @default(uuid())
  sessionId       String    @map("session_id")
  tokenHash       String    @map("token_hash") // SHA-256 hash — raw token NEVER stored
  nonce           String
  generatedAt     DateTime  @default(now()) @map("generated_at")
  expiresAt       DateTime  @map("expires_at")
  isExpired       Boolean   @default(false) @map("is_expired")
  revoked         Boolean   @default(false)
  usedAt          DateTime? @map("used_at") // set on first successful scan (replay prevention)
  usedByStudentId String?   @map("used_by_student_id")

  session AttendanceSession @relation(fields: [sessionId], references: [sessionId])

  @@unique([tokenHash])
  @@index([sessionId, expiresAt])
  @@map("attendance_qr_history")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_DUTY
  LEAVE
  REJECTED_DUPLICATE
  REJECTED_EXPIRED
  REJECTED_GEOFENCE
  REJECTED_INVALID_SIGNATURE
}

enum AttendanceMethod {
  QR
  ACOUSTIC
  FACULTY_MANUAL
}

model AttendanceRecord {
  id                         String           @id @default(uuid())
  studentId                  String           @map("student_id")
  sessionId                  String           @map("session_id")
  scanTime                   DateTime         @default(now()) @map("scan_time")
  gpsLat                     Float?           @map("gps_lat")
  gpsLng                     Float?           @map("gps_lng")
  gpsAccuracy                Float?           @map("gps_accuracy")
  distanceFromCampus         Float?           @map("distance_from_campus")
  locationVerified           Boolean          @default(false) @map("location_verified")
  locationVerificationStatus String?          @map("location_verification_status")
  locationVerifiedAt         DateTime?        @map("location_verified_at")
  status                     AttendanceStatus @default(PRESENT)
  method                     AttendanceMethod @default(QR)
  deviceId                   String?          @map("device_id")
  markedByFacultyId          String?          @map("marked_by_faculty_id")
  overrideReason             String?          @map("override_reason")
  createdAt                  DateTime         @default(now()) @map("created_at")
  updatedAt                  DateTime         @updatedAt @map("updated_at")

  student Student           @relation(fields: [studentId], references: [id])
  session AttendanceSession @relation(fields: [sessionId], references: [sessionId])

  // A student can only ever have ONE successful PRESENT record per session.
  @@unique([studentId, sessionId], name: "uq_student_session")
  @@index([sessionId])
  @@index([method])
  @@map("attendance_record")
}

enum LeaveRequestType {
  LEAVE
  ON_DUTY
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id         String             @id @default(uuid())
  studentId  String             @map("student_id")
  type       LeaveRequestType
  fromDate   DateTime           @map("from_date")
  toDate     DateTime           @map("to_date")
  reason     String
  status     LeaveRequestStatus @default(PENDING)
  reviewNote String?            @map("review_note")
  reviewedBy String?            @map("reviewed_by")
  reviewedAt DateTime?          @map("reviewed_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, createdAt])
  @@index([status, createdAt])
  @@map("leave_request")
}

// ------------------------------------------------------------
// Security: Audit Logging
// ------------------------------------------------------------

enum ActorType {
  ADMIN
  FACULTY
  STUDENT
  SYSTEM
}

// Durable, append-only record of every security-relevant event:
// auth (login/refresh/logout/failed attempts), session lifecycle,
// and every scan outcome (accepted AND rejected, with reason).
// Redis holds live session/refresh-token state; this table is the
// permanent, queryable trail for compliance/incident review.
model AuditLog {
  id         String    @id @default(uuid())
  actorId    String?   @map("actor_id") // null for pre-auth events e.g. failed login by unknown email
  actorType  ActorType @map("actor_type")
  action     String // e.g. "LOGIN_SUCCESS", "LOGIN_FAILED", "SCAN_ACCEPTED", "SCAN_REJECTED", "SESSION_STARTED"
  success    Boolean   @default(true)
  reasonCode String?   @map("reason_code") // e.g. AppError.code on failure
  sessionId  String?   @map("session_id") // attendance session, if applicable
  ip         String?
  userAgent  String?   @map("user_agent")
  metadata   Json? // small structured extra context (never secrets/tokens)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([sessionId])
  @@map("audit_log")
}
